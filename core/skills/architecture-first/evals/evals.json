        {
          "name": "does_not_recommend_new_third_party_sdk",
          "type": "keyword_absent_or_explicitly_rejected",
          "keywords": [
            "Toast-Swift",
            "SwiftMessages",
            "SVProgressHUD",
            "MBProgressHUD"
          ]
